<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssFontSubset.Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lang="clr-namespace:AssFontSubset.Avalonia.I18n"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="680"
        Width="1000" Height="680" MinWidth="820" MinHeight="560"
        x:Class="AssFontSubset.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}">

  <DockPanel LastChildFill="True">

    <ProgressBar DockPanel.Dock="Bottom" Height="6" Margin="0"
                 IsIndeterminate="{Binding IsBusy}" />

    <TabControl x:Name="tabControl">

      <!-- ===================== Subset Tab ===================== -->
      <TabItem Header="{x:Static lang:Resources.Subset}">
        <Grid Margin="10" RowDefinitions="*,Auto,Auto,Auto,Auto,140">

          <!-- ASS files -->
          <Grid Grid.Row="0" RowDefinitions="Auto,*" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static lang:Resources.InputAssFiles}" FontSize="16" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Button Content="{x:Static lang:Resources.AddFiles}" Click="AddAss_Click"/>
              <Button Content="{x:Static lang:Resources.ClearInput}" Command="{Binding ClearAssFilesCommand}"/>
            </StackPanel>
            <ListBox x:Name="AssFileList" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,4,0,0"
                     ItemsSource="{Binding AssFiles}"
                     DragDrop.AllowDrop="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
          </Grid>

          <!-- Output folder -->
          <Grid Grid.Row="1" ColumnDefinitions="120,*,Auto" Margin="0,4">
            <TextBlock Grid.Column="0" Text="{x:Static lang:Resources.OutputFolder}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding OutputFolder}" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="{x:Static lang:Resources.Browse}" Margin="6,0,0,0" Click="BrowseOutput_Click"/>
          </Grid>

          <!-- Font source -->
          <Grid Grid.Row="2" ColumnDefinitions="120,*,Auto" Margin="0,4">
            <CheckBox Grid.Column="0" Grid.ColumnSpan="3" IsChecked="{Binding UseDatabase}"
                      Content="{x:Static lang:Resources.UseDatabaseOption}"
                      ToolTip.Tip="{x:Static lang:Resources.UseDatabaseOptionTip}"/>
          </Grid>
          <Grid Grid.Row="3" ColumnDefinitions="120,*,Auto" Margin="0,4"
                IsEnabled="{Binding !UseDatabase}">
            <TextBlock Grid.Column="0" Text="{x:Static lang:Resources.InputFontFolder}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding FontFolder}" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="{x:Static lang:Resources.Browse}" Margin="6,0,0,0" Click="BrowseFontFolder_Click"/>
          </Grid>

          <!-- Options + Start -->
          <Grid Grid.Row="4" ColumnDefinitions="*,200" Margin="0,6">
            <StackPanel Grid.Column="0" Spacing="2">
              <CheckBox Content="{x:Static lang:Resources.SourceHanEllipsis}" IsChecked="{Binding SourceHanEllipsis}" ToolTip.Tip="{x:Static lang:Resources.SourceHanEllipsisTip}"/>
              <CheckBox Content="{x:Static lang:Resources.BackendHarfbuzzSubset}" IsChecked="{Binding UseHarfBuzz}" ToolTip.Tip="{x:Static lang:Resources.BackendHarfbuzzSubsetTip}"/>
              <CheckBox Content="{x:Static lang:Resources.ConvertOtfToTtf}" IsChecked="{Binding ConvertOtfToTtf}" ToolTip.Tip="{x:Static lang:Resources.ConvertOtfToTtfTip}"/>
              <CheckBox Content="{x:Static lang:Resources.DebugOption}" IsChecked="{Binding DebugMode}" ToolTip.Tip="{x:Static lang:Resources.DebugOptionTip}"/>
              <Grid ColumnDefinitions="Auto,*" Margin="0,4,0,0">
                <TextBlock Grid.Column="0" Text="{x:Static lang:Resources.PythonPathLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding PythonPath}" VerticalContentAlignment="Center"/>
              </Grid>
            </StackPanel>
            <Button Grid.Column="1" Content="{x:Static lang:Resources.StartButton}"
                    Command="{Binding StartSubsetCommand}"
                    Margin="10,0,0,0" FontSize="32"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
          </Grid>

          <!-- Log -->
          <Grid Grid.Row="5" RowDefinitions="Auto,*" Margin="0,4,0,0">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{x:Static lang:Resources.LogLabel}" FontSize="14" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Content="{x:Static lang:Resources.ClearLog}" Command="{Binding ClearLogCommand}"/>
            </Grid>
            <TextBox Grid.Row="1" Text="{Binding LogText}" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="Wrap" FontFamily="Consolas,Menlo,monospace" FontSize="12"
                     VerticalAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
          </Grid>

        </Grid>
      </TabItem>

      <!-- ===================== Font Library Tab ===================== -->
      <TabItem Header="{x:Static lang:Resources.FontLibrary}">
        <Grid Margin="10" RowDefinitions="Auto,160,Auto,Auto,Auto,*">

          <TextBlock Grid.Row="0" Text="{x:Static lang:Resources.LibraryFolders}" FontSize="16" Margin="0,0,0,4"/>

          <ListBox x:Name="LibraryFolderList" Grid.Row="1"
                   ItemsSource="{Binding LibraryFolders}"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

          <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,6">
            <Button Content="{x:Static lang:Resources.AddFolder}" Click="AddLibraryFolder_Click"/>
            <Button Content="{x:Static lang:Resources.Remove}"
                    Command="{Binding RemoveLibraryFolderCommand}"
                    CommandParameter="{Binding #LibraryFolderList.SelectedItem}"/>
          </StackPanel>

          <Grid Grid.Row="3" ColumnDefinitions="120,*,Auto" Margin="0,6">
            <TextBlock Grid.Column="0" Text="{x:Static lang:Resources.DatabasePathLabel}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding DatabasePath}" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="{x:Static lang:Resources.Browse}" Margin="6,0,0,0" Click="BrowseDatabase_Click"/>
          </Grid>

          <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,6">
            <Button Grid.Column="0" Content="{x:Static lang:Resources.BuildDatabase}"
                    Command="{Binding BuildDatabaseCommand}" FontSize="16" Padding="16,8"/>
            <TextBlock Grid.Column="1" Text="{Binding DatabaseSummary}" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14"/>
          </Grid>

          <Grid Grid.Row="5" RowDefinitions="Auto,*" Margin="0,6,0,0">
            <TextBlock Grid.Row="0" Text="{x:Static lang:Resources.IndexedFonts}" FontSize="14" Margin="0,0,0,4"/>
            <ListBox Grid.Row="1" ItemsSource="{Binding DatabaseFonts}"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding FamilyDisplay}" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.7"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Detail}" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.85"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>

        </Grid>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>
